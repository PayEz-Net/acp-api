# acp-api — copy to .env and fill with your own values.
# .env is gitignored; this .env.example is the committed schema reference.
# No real secrets or internal hostnames belong in this file.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001                         # API listen port
NODE_ENV=development              # development | production
LOG_LEVEL=info                    # debug | info | warn | error
CORS_ALLOWED_ORIGINS=             # comma-separated origins; empty = same-origin only

# ── Local shell auth ─────────────────────────────────────────────────────────
# Shared secret for the Electron callback <-> acp-api internal channel.
ACP_LOCAL_SECRET=
ACP_CALLBACK_PORT=                # Electron callback server port (set by the desktop shell)

# ── Vibe cloud API (IDP-authenticated) ───────────────────────────────────────
VIBE_API_URL=https://api.idealvibe.online   # public Vibe API
IDP_URL=                          # your IDP base URL (OAuth / device-code)
VIBE_AUTH_MODE=bearer             # bearer (IDP) | hmac (legacy client-secret)
VIBE_TOKEN_CMD=                   # external command that prints a bearer token, if used
VIBE_TOKEN_REFRESH_S=             # token refresh interval (seconds)

# ── Vibe HMAC (legacy client-secret lane; leave blank when using bearer) ──────
# Matches a row in your own IDP's vibe_client_credentials (client_id + signing key).
# Pull from your own IDP DB — never commit real values.
VIBE_CLIENT_ID=
VIBE_HMAC_KEY=
VIBE_SIGNING_KEY=

# ── VibeSQL (optional raw lane; absent = those consumers hard-fail, no fallback) ─
VIBESQL_URL=                      # e.g. http://localhost:52411
VIBESQL_DIRECT_URL=               # optional direct endpoint override
VIBESQL_SECRET=
VIBESQL_CONTAINER_SECRET=

# ── Contractors / execution ───────────────────────────────────────────────────
ENABLE_CONTRACTORS=false
ACP_CONTRACTOR_CMD=               # contractor CLI command
ACP_MAX_CONTRACTORS=              # max concurrent contractors
ACP_QUEUE_TIMEOUT_MINUTES=        # contractor queue timeout
ACP_SKIP_CLI_CHECK=false          # skip the CLI-present preflight (dev only)
ACP_AGENTS=                       # optional agent roster override
EXEC_TIMEOUT_MS=                  # per-exec timeout (milliseconds)

# ── Autonomy / party engine ────────────────────────────────────────────────────
AUTONOMY_MAX_RUNTIME_HOURS=       # cap on unattended runtime
ESCALATION_SENSITIVITY=           # escalation threshold
PARTY_TICK_MS=                    # party-engine tick interval (milliseconds)

# ── Dev scripts / test harnesses (optional; not needed to run the server) ──────
SKILLS_DIR=                       # seed-specialist-library.cjs: skills source dir
START_ID=                         # seed-specialist-library.cjs: starting id (default 201)
TARGET_COUNT=                     # seed-specialist-library.cjs: rows to seed (default 60)
RUNTIME=                          # test harness only: runtime under test (claude|kimi)
